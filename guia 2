Console.WriteLine("Hello, World!");
// Un programa que solicite un numero de 1 al 7
//Mostrar en pantalla los dias de l asemna segun el numero 
//Ingresado
static void Main(string[]args)
{
    Console.WriteLine("***************");
    Console.WriteLine("DIAS DE LA SEMNA");
    Console.WriteLine("****************");

    int dia;
    Console.WriteLine("Digite un valor entereo del 1 al 7");
    dia = Convert.ToInt32(Console.ReadLine());
    switch (dia)
    {
        case 1:
            Console.WriteLine("Lunes");
            break;
        case 2:
            Console.WriteLine("Martes");
            break;
        case 3:
            Console.WriteLine("Miercoles");
            break;
        case 4:
            Console.WriteLine("Jueves");
            break;
        case 5:
            Console.WriteLine("Viernes");
            break;
        case 6:
            Console.WriteLine("Sabado");
            break;
        case 7:
            Console.WriteLine("Domingo");
            break;
        default:
            Console.WriteLine("Escribir un valor valido del 1 al 7");
            break;
    }
}